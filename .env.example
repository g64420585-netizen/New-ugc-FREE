  # URL do webhook do Discord para logs do site
  # Como obter: Servidor Discord > Configurações do Canal > Integrações > Webhooks
  VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/SEU_ID/SEU_TOKEN
  